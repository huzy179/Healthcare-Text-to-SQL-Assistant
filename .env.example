POSTGRES_DB=healthcare
POSTGRES_USER=healthcare_user
POSTGRES_PASSWORD=healthcare_password
POSTGRES_PORT=5433
POSTGRES_READONLY_USER=healthcare_readonly
POSTGRES_READONLY_PASSWORD=readonly_password

# Host URL for local scripts.
DATABASE_URL=postgresql://healthcare_readonly:readonly_password@localhost:5433/healthcare

# Docker services use postgres:5432 internally.
DOCKER_DATABASE_URL=postgresql://healthcare_readonly:readonly_password@postgres:5432/healthcare

MCP_QUERY_TIMEOUT_MS=30000
MCP_MAX_ROWS=200

# Used by the eval Docker service so generated reports are writable by the host user.
LOCAL_UID=1000
LOCAL_GID=1000

FRONTEND_PORT=3000

# Required for real LLM SQL generation in the Next.js frontend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Use these instead of OpenAI_* when pointing the frontend to local vLLM.
LLM_BASE_URL=http://vllm:8000/v1
LLM_API_KEY=local
LLM_MODEL=qwen-coder-3b

# Optional local vLLM service.
VLLM_PORT=8000
VLLM_MODEL=Qwen/Qwen2.5-Coder-3B-Instruct
VLLM_SERVED_MODEL_NAME=qwen-coder-3b
VLLM_API_KEY=local
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.85
HF_HOME=~/.cache/huggingface
HF_TOKEN=
